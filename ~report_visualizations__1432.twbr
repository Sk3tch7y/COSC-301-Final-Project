    c.client_id,
    c.card_brand,
    CAST(c.credit_limit AS NUMERIC) AS credit_limit,
    s.active_year
FROM cards_data c
CROSS JOIN LATERAL generate_series(
    CAST(EXTRACT(YEAR FROM c.acct_open_date) AS INT), 
    CAST(EXTRACT(YEAR FROM c.expires) AS INT)
) AS s(active_year)</relation>
            </properties>
          </object>
