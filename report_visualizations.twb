        <relation type='collection'>
          <relation connection='genericjdbc.13g9c5o1q8yfjb161371v096qiep' name='cards_data' table='[public].[cards_data]' type='table' />
          <relation connection='genericjdbc.13g9c5o1q8yfjb161371v096qiep' name='Custom SQL Query' type='text'>SELECT 
    c.id AS card_id,
    c.client_id,
    c.card_brand,
    CAST(c.credit_limit AS NUMERIC) AS credit_limit,
    s.active_year
FROM cards_data c
CROSS JOIN LATERAL generate_series(
    CAST(EXTRACT(YEAR FROM c.acct_open_date) AS INT), 
    CAST(EXTRACT(YEAR FROM c.expires) AS INT)
) AS s(active_year)</relation>
          <relation connection='genericjdbc.13g9c5o1q8yfjb161371v096qiep' name='clients_data' table='[public].[clients_data]' type='table' />
          <relation connection='genericjdbc.13g9c5o1q8yfjb161371v096qiep' name='transactions_data' table='[public].[transactions_data]' type='table' />
        </relation>
