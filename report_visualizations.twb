      <column caption='Age Group' datatype='string' name='[Calculation_2546250346491904]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [current_age] &lt; 25 THEN &quot;18-24&quot;&#13;&#10;ELSEIF [current_age] &lt; 35 THEN &quot;25-34&quot;&#13;&#10;ELSEIF [current_age] &lt; 45 THEN &quot;35-44&quot;&#13;&#10;ELSEIF [current_age] &lt; 55 THEN &quot;45-54&quot;&#13;&#10;ELSE &quot;55+&quot;&#13;&#10;END' />
      </column>
      <column caption='Credit Usage' datatype='real' name='[Calculation_2546250350252033]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([amount]) / SUM([credit_limit])' />
      </column>
      <column caption='Spending Per Client' datatype='real' name='[Calculation_2546250361921538]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([amount]) / COUNTD([client_id])' />
      </column>
      <column caption='Valid Span' datatype='string' name='[Calculation_5314544995127298]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[acct_open_date] + [expires]' />
